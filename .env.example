# ─── Brevo (Sendinblue) Email API ────────────────────────────────────────────
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here

# Your email address — receives contact form notifications
OWNER_EMAIL=bc833498@gmail.com

# ─── Google Search Console verification ──────────────────────────────────────
# Get from: https://search.google.com/search-console → Settings → Ownership verification → HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-token-here

# ─── Bing Webmaster Tools verification ───────────────────────────────────────
# Get from: https://www.bing.com/webmasters → Add your site → HTML Meta Tag method
# Copy only the content value (not the full meta tag)
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-token-here
